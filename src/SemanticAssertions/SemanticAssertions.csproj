<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>SemanticAssertions</PackageId>
    <Version>0.1.0</Version>
    <Description>Fluent semantic assertions for testing agentic behavior and non-deterministic code. Uses LLM-based grading with essential state validation inspired by dominator analysis.</Description>
    <Authors>Daniel Olvera</Authors>
    <PackageTags>testing;assertions;ai;agents;mcp;semantic;non-deterministic;fluent</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/daolvera/SemanticAssertions</RepositoryUrl>
    <PackageProjectUrl>https://github.com/daolvera/SemanticAssertions</PackageProjectUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <PropertyGroup>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="SemanticAssertions.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.6.0" />
    <PackageReference Include="ModelContextProtocol" Version="1.3.0" />
  </ItemGroup>

</Project>
